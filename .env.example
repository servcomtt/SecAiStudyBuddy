# ──────────────────────────────────────────────────────────────────────────────
# Study Buddy — Environment Variables
# Copy this file to .env and fill in the values before running.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Ports ─────────────────────────────────────────────────────────────────────
LMS_PORT=3001
ORCH_PORT=3002
IMPORTER_PORT=3003

# ── Security — CHANGE THESE IN PRODUCTION ────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
WEBHOOK_SECRET=replace-with-another-long-random-string
# Shared secret between LMS and question-importer (service-to-service auth)
LMS_API_KEY=replace-with-a-long-random-string
# Optional dedicated importer key (defaults to LMS_API_KEY)
IMPORTER_API_KEY=
# Shared secret for lab-orchestrator routes (defaults to WEBHOOK_SECRET)
ORCHESTRATOR_API_KEY=
# Internal URL for LMS → orchestrator proxy (Docker: http://lab-orchestrator:3002)
LAB_ORCHESTRATOR_URL=http://localhost:3002

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to the origin serving index.html (e.g. https://studybuddy.yourdomain.com)
CORS_ORIGIN=http://localhost:3000

# ── Ollama (study-spa AI via LMS proxy /sb-ollama/*) ───────────────────────────
# Where the Node server reaches Ollama (browser uses same-origin /sb-ollama on port 3001).
# From Docker on Windows/Mac, 127.0.0.1 is the container — use host Ollama via e.g.:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── Database ──────────────────────────────────────────────────────────────────
# Leave DATABASE_URL empty to use SQLite (zero-config, stored in the lms-db volume).
# Set to a postgres:// connection string to switch to PostgreSQL.
DATABASE_URL=

# Certificate number prefix printed on completion certificates
CERT_PREFIX=SB

# ── Lab containers ────────────────────────────────────────────────────────────
SESSION_TTL_MS=900000        # idle TTL before auto-cleanup (ms) — 900000 = 15 min
LAB_MEMORY_BYTES=268435456   # RAM per container — 268435456 = 256 MB
LAB_CPU_QUOTA=50000          # CFS quota (50000 / 100000 period = 50% of 1 core)

# ── Question Importer ─────────────────────────────────────────────────────────
MAX_FILE_MB=50               # Max upload size in MB for document imports
