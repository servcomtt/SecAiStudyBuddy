{
  "name": "studybuddy-lab-orchestrator",
  "version": "1.0.0",
  "description": "Docker container lifecycle manager for Study Buddy lab exercises",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:python": "docker build -t studybuddy-python-lab:latest ./lab-environments/python",
    "build:all": "npm run build:python",
    "clean": "docker ps -a --filter name=lab- --format '{{.ID}}' | xargs -r docker rm -f"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dockerode": "^4.0.9",
    "express": "^5.2.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
